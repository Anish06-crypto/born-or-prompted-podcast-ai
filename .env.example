# Groq — add one key per account, comma-separated (no spaces)
# Get keys at: console.groq.com
GROQ_API_KEYS=gsk_key1,gsk_key2,gsk_key3

# Agent models & providers — override to swap models without touching code
# Provider options: groq | gemini | openai
AGENT_A_MODEL=llama-3.3-70b-versatile
AGENT_B_MODEL=qwen/qwen3-32b
AGENT_A_PROVIDER=groq
AGENT_B_PROVIDER=groq

# ElevenLabs — single key + two voice IDs (one per agent)
# Get key at: elevenlabs.io → Profile → API Keys
# Get voice IDs at: elevenlabs.io/voice-library → click a voice → copy ID from URL
ELEVENLABS_API_KEY=sk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ELEVENLABS_MODEL=eleven_turbo_v2_5
VOICE_ID_LYRA=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
VOICE_ID_CIPHER=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Reddit — optional, only needed for auto topic fetch
# Create app at: reddit.com/prefs/apps → "create another app" → type: script
REDDIT_CLIENT_ID=xxxxxxxxxxxxxxxxxxxx
REDDIT_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
REDDIT_USER_AGENT=podcast_ai/1.0
